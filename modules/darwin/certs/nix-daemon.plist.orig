<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>systems.determinate.nix-daemon</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/determinate-nixd</string>
		<string>daemon</string>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<key>Sockets</key>
	<dict>
		<key>determinate-nixd.socket</key>
		<dict>
			<key>SockFamily</key>
			<string>Unix</string>
			<key>SockPassive</key>
			<true/>
			<key>SockPathName</key>
			<string>/var/run/determinate-nixd.socket</string>
		</dict>
		<key>nix-daemon.socket</key>
		<dict>
			<key>SockFamily</key>
			<string>Unix</string>
			<key>SockPassive</key>
			<true/>
			<key>SockPathName</key>
			<string>/var/run/nix-daemon.socket</string>
		</dict>
	</dict>
	<key>StandardErrorPath</key>
	<string>/var/log/determinate-nix-daemon.log</string>
	<key>StandardOutPath</key>
	<string>/var/log/determinate-nix-daemon.log</string>
	<key>SoftResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>1048576</integer>
		<key>NumberOfProcesses</key>
		<integer>1048576</integer>
		<key>Stack</key>
		<integer>67108864</integer>
	</dict>
	<key>HardResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>1048576</integer>
		<key>NumberOfProcesses</key>
		<integer>1048576</integer>
		<key>Stack</key>
		<integer>67108864</integer>
	</dict>
</dict>
</plist>
